<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#F0F0F0" /> <!-- The background color of the pressed state -->
            <corners android:radius="28dp" /> <!-- corner radius -->
            <stroke
                android:width="1dp"
                android:color="#000000" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#FFFFFF" /> <!-- Default background color -->
            <corners android:radius="28dp" /> <!-- corner radius -->
            <stroke
                android:width="1dp"
                android:color="#000000" />
        </shape>
    </item>

</selector>