<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/black" /> <!-- The background color of the pressed state -->
            <stroke android:color="@color/green"
                android:width="2dp"/>
            <corners android:radius="24dp" /> <!-- corner radius -->
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/black" /> <!-- Default background color -->
            <corners android:radius="24dp" /> <!-- corner radius -->
            <stroke
                android:width="2dp"
                android:color="@color/green" />
        </shape>
    </item>
</selector>