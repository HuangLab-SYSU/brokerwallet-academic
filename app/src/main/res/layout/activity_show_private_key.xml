<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".xc.ShowPrivateKeyActivity">

    <!-- Top Bar -->
    <include
        layout="@layout/topbar"
        android:id="@+id/action_bar"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/action_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/activity_show_private_key_private_key"
                android:fontFamily="@font/work_sans_black"
                android:textSize="@dimen/text_size_xlarge"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center" />

            <!-- Description -->
            <TextView
                android:id="@+id/Warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/activity_show_private_key_never_disclose"
                android:textSize="@dimen/text_size_normal"
                android:textColor="#CC0000"
                android:gravity="center" />

            <TextView
                android:id="@+id/WarningDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/activity_show_private_key_theft_warning"
                android:textSize="@dimen/text_size_small"
                android:textColor="#000000"
                android:gravity="center" />


            <!-- Private Key Display (Hidden by default) -->
            <TextView
                android:id="@+id/privateKeyTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••••"
                android:textSize="@dimen/text_size_small"
                android:textColor="#000000"
                android:gravity="center"
                android:singleLine="false"
                android:maxLines="3" />

            <!-- Reveal Button (Long press to show private key) -->
            <android.widget.Button
                android:id="@+id/revealButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="32dp"
                android:background="@drawable/custom_button_background"
                android:text="@string/activity_show_private_key_long_press"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_normal" />

            <!-- Copy Button (Initially hidden, shown after reveal) -->
            <android.widget.Button
                android:id="@+id/copyButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="16dp"
                android:background="@drawable/custom_button_background_black"
                android:text="@string/activity_show_private_key_copy_key"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_normal"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>