<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <include layout="@layout/topbar" />

    <include
        layout="@layout/include_token_sub_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/action_bar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/token_sub_header"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/token_info_intro_label"
                android:textColor="#64748B"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/token_info_intro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/token_card_bg"
                android:lineSpacingExtra="5dp"
                android:padding="14dp"
                android:text="@string/token_info_intro_body"
                android:textColor="#374151"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/token_info_address_label"
                android:textColor="#64748B"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/token_card_bg"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/token_info_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="3dp"
                    android:textColor="#0F172A"
                    android:textIsSelectable="true"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/token_info_copy_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/token_copy_chip"
                    android:drawableStart="@drawable/ic_token_copy"
                    android:drawablePadding="4dp"
                    android:paddingStart="10dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp"
                    android:text="@string/token_copy"
                    android:textColor="#1A73E8"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/token_info_source_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/token_info_source_label"
                android:textColor="#64748B"
                android:textSize="14sp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/token_card_bg"
                android:fillViewport="true"
                android:padding="12dp"
                android:scrollbars="horizontal">

                <TextView
                    android:id="@+id/token_info_source"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp"
                    android:textColor="#1F2937"
                    android:textIsSelectable="true"
                    android:textSize="11sp" />
            </HorizontalScrollView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>
