<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".xc.StakeMoreActivity">

    <!-- Top Bar -->
    <include
        layout="@layout/topbar"
        android:id="@+id/action_bar"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title Section -->
    <TextView
        android:id="@+id/stakemoretext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        android:text="Stake more"
        android:fontFamily="@font/work_sans_black"
        android:textSize="@dimen/text_size_xlarge"
        android:textStyle="bold"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/action_bar" />

    <!-- Description Text -->
    <TextView
        android:id="@+id/tv_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:text="Transfer your coins securely to broker system address"
        android:textSize="@dimen/text_size_normal"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/stakemoretext" />

    <!-- Scrollable Form Area -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_description"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Send From Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send from"
                android:textSize="@dimen/text_size_normal"
                android:textColor="#000000" />

            <!-- Send From Input -->
            <EditText
                android:id="@+id/edt_sendfrom"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edittext_height"
                android:layout_marginTop="8dp"
                android:background="@drawable/custom_edittext_border"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textSize="@dimen/text_size_normal" />

            <!-- Send To Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Send to"
                android:textSize="@dimen/text_size_normal"
                android:textColor="#000000" />

            <!-- Send To Input -->
            <EditText
                android:id="@+id/edt_sendto"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edittext_height"
                android:layout_marginTop="8dp"
                android:background="@drawable/custom_edittext_border"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:textSize="@dimen/text_size_normal" />

            <!-- Amount Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Amount"
                android:textSize="@dimen/text_size_normal"
                android:textColor="#000000" />

            <!-- Amount Input -->
            <EditText
                android:id="@+id/stakeamount"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edittext_height"
                android:layout_marginTop="8dp"
                android:background="@drawable/custom_edittext_border"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textSize="@dimen/text_size_normal" />

            <!-- Stake Button -->
            <android.widget.Button
                android:id="@+id/stakemorebtn"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="32dp"
                android:background="@drawable/custom_button_background"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:text="Stake"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_normal" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>