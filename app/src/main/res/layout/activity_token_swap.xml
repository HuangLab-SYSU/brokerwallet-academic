<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <include layout="@layout/topbar" />

    <include
        layout="@layout/include_token_sub_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/action_bar" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/token_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/token_sub_header">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingEnd="16dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/token_pay_label"
                    android:textColor="#0F172A"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/token_pay_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:background="@drawable/token_swap_card"
                    android:gravity="center_vertical"
                    android:minHeight="116dp"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="18dp">

                    <EditText
                        android:id="@+id/token_pay_amount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical"
                        android:hint="0"
                        android:inputType="numberDecimal"
                        android:minHeight="56dp"
                        android:textColor="#0F172A"
                        android:textColorHint="#CBD5E1"
                        android:textSize="38sp" />

                    <LinearLayout
                        android:id="@+id/token_pay_token_selector"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/token_selector_press_feedback"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="end"
                        android:minWidth="128dp"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="6dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/token_pay_token_icon"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/token_list_icon_bg"
                                android:gravity="center"
                                android:text="B"
                                android:textColor="@color/white"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/token_pay_symbol"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="BKC"
                                android:textColor="#0F172A"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_marginStart="2dp"
                                android:contentDescription="@string/token_picker_open"
                                android:src="@drawable/ic_token_chevron_down" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/token_pay_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/token_balance_loading"
                            android:textColor="#A0AEC0"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:id="@+id/token_pay_max_container"
                            android:layout_width="wrap_content"
                            android:layout_gravity="end"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/token_pay_max"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/token_max_text_button"
                                android:clickable="true"
                                android:focusable="true"
                                android:gravity="center"
                                android:minHeight="18dp"
                                android:paddingTop="0dp"
                                android:paddingBottom="0dp"
                                android:text="@string/token_max"
                                android:textColor="@drawable/token_max_text_color"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/token_receive_section_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="@string/token_receive_label"
                    android:textColor="#0F172A"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toTopOf="@id/token_receive_card"
                    app:layout_constraintStart_toStartOf="parent" />

                <LinearLayout
                    android:id="@+id/token_receive_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="92dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/token_pay_card"
                    android:background="@drawable/token_swap_card"
                    android:gravity="center_vertical"
                    android:minHeight="116dp"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="18dp">

                    <HorizontalScrollView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fillViewport="false"
                        android:scrollbars="none">

                        <TextView
                            android:id="@+id/token_receive_amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:minHeight="56dp"
                            android:maxLines="1"
                            android:scrollHorizontally="true"
                            android:singleLine="true"
                            android:text="0"
                            android:textColor="#94A3B8"
                            android:textSize="38sp" />

                    </HorizontalScrollView>

                    <LinearLayout
                        android:id="@+id/token_receive_token_selector"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/token_selector_press_feedback"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="end"
                        android:minWidth="128dp"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="6dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/token_receive_token_icon"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/token_list_icon_bg"
                                android:gravity="center"
                                android:text="W"
                                android:textColor="@color/white"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/token_receive_symbol"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="wBKC"
                                android:textColor="#0F172A"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_marginStart="2dp"
                                android:contentDescription="@string/token_picker_open"
                                android:src="@drawable/ic_token_chevron_down" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/token_receive_balance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginTop="4dp"
                            android:text="@string/token_balance_loading"
                            android:textColor="#A0AEC0"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/token_swap_direction"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/token_swap_fab"
                    android:clickable="true"
                    android:contentDescription="@string/token_swap_direction_desc"
                    android:elevation="10dp"
                    android:focusable="true"
                    android:padding="10dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/jiaohuan"
                    app:layout_constraintBottom_toTopOf="@id/token_receive_card"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/token_pay_card"
                    app:layout_constraintVertical_bias="0.5" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <android.widget.Button
                    android:id="@+id/token_confirm_button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/token_btn_wrap_selector"
                    android:backgroundTint="@null"
                    android:enabled="false"
                    android:letterSpacing="0.02"
                    android:stateListAnimator="@null"
                    android:text="@string/token_button_enter_amount"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</RelativeLayout>
