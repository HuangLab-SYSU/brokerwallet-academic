<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".xc.ConfirmPasswordActivity">

    <!-- Top Bar -->
    <include
        layout="@layout/topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollable Content Area -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/action_bar"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp">

            <!-- Title (Centered) -->
            <TextView
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirm Identity"
                android:fontFamily="@font/work_sans_black"
                android:textSize="@dimen/text_size_xlarge"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Description (Centered) -->
            <TextView
                android:id="@+id/description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Please enter your wallet password to view the private key"
                android:textSize="@dimen/text_size_normal"
                android:textColor="#000000"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/title" />

            <!-- Password Input Field -->
            <EditText
                android:id="@+id/passwordEditText"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edittext_height"
                android:layout_marginTop="32dp"
                android:background="@drawable/custom_edittext_border"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:textSize="@dimen/text_size_normal"
                android:hint="Enter password"
                app:layout_constraintTop_toBottomOf="@id/description" />

            <!-- Confirm Button -->
            <android.widget.Button
                android:id="@+id/confirmBtn"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="32dp"
                android:background="@drawable/custom_button_background"
                android:text="Confirm"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_normal"
                app:layout_constraintTop_toBottomOf="@id/passwordEditText" />

            <!-- Cancel Button -->
            <android.widget.Button
                android:id="@+id/cancelBtn"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/custom_button_bg_white"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="@dimen/text_size_normal"
                app:layout_constraintTop_toBottomOf="@id/confirmBtn" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>