<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="64dp"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="4dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/token_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/token_list_icon_bg"
        android:gravity="center"
        android:text="W"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/token_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#0F172A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/token_symbol"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#94A3B8"
            android:textSize="13sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/token_switch_wrap"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:minWidth="56dp"
        android:minHeight="48dp"
        android:paddingStart="8dp"
        android:paddingEnd="12dp">

        <FrameLayout
            android:id="@+id/token_switch_track"
            android:layout_width="52dp"
            android:layout_height="28dp"
            android:layout_gravity="center">

            <View
                android:id="@+id/token_switch_thumb"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="3dp"
                android:background="@drawable/token_toggle_thumb" />
        </FrameLayout>
    </FrameLayout>
</LinearLayout>
