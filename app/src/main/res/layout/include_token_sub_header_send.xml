<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/token_sub_header"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <View
        android:layout_width="92dp"
        android:layout_height="40dp" />

    <TextView
        android:id="@+id/token_page_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/work_sans_black"
        android:gravity="center"
        android:text="@string/token_send_title"
        android:textColor="#000000"
        android:textSize="17sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="92dp"
        android:layout_height="wrap_content"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/token_send_scan"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/token_send_tool_button"
            android:clickable="true"
            android:contentDescription="@string/token_scan"
            android:focusable="true"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/saoma" />

        <ImageView
            android:id="@+id/token_send_gallery"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/token_send_tool_button"
            android:clickable="true"
            android:contentDescription="@string/token_scan_from_gallery"
            android:focusable="true"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/xiangce" />
    </LinearLayout>
</LinearLayout>
