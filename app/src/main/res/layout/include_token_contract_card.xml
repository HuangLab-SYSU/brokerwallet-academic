<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/token_contract_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/token_card_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/token_contract_label"
            android:textColor="#64748B"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/token_contract_copy_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/token_copy_chip"
            android:drawableStart="@drawable/ic_token_copy"
            android:drawablePadding="4dp"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            android:text="@string/token_copy"
            android:textColor="#1A73E8"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/token_contract_address_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="monospace"
        android:lineSpacingExtra="2dp"
        android:text="@string/token_contract_missing_short"
        android:textColor="#0F172A"
        android:textIsSelectable="true"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/token_contract_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/token_contract_hint"
        android:textColor="#94A3B8"
        android:textSize="12sp" />
</LinearLayout>
