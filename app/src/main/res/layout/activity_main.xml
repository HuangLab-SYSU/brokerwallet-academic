<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".xc.MainActivity">

    <!-- Top Bar -->
    <include
        android:id="@+id/action_bar"
        layout="@layout/topbar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Account Spinner -->
    <Spinner
        android:id="@+id/accountSpinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/action_bar"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Welcome Text Section -->
    <TextView
        android:id="@+id/WTextview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/work_sans_black"
        android:maxLines="3"
        android:text="Please add an account first."
        android:textColor="#000000"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/accountSpinner"
        app:layout_constraintBottom_toTopOf="@+id/icon_grid_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle Text -->
    <TextView
        android:id="@+id/tsv_dollar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Click on the top right corner -> Settings -> Account -> Add account."
        android:textColor="#FF0000"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/WTextview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Icon Grid Container (2 rows × 4 columns) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/icon_grid_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="34dp"
        app:layout_constraintTop_toBottomOf="@id/tsv_dollar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ==================== ROW 1: Faucet, Send, Receive, Swap ==================== -->

        <!-- Row 1 Icons -->
        <ImageView
            android:id="@+id/buy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:src="@drawable/plus_icon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/send"
            app:layout_constraintHorizontal_chainStyle="packed" />

        <ImageView
            android:id="@+id/send"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:src="@drawable/send_icon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/buy"
            app:layout_constraintEnd_toStartOf="@+id/receiveicon" />

        <ImageView
            android:id="@+id/receiveicon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:src="@drawable/qrcode_icon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/send"
            app:layout_constraintEnd_toStartOf="@+id/swap" />

        <ImageView
            android:id="@+id/swap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:src="@drawable/transaction_icon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/receiveicon"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Row 1 Labels -->
        <TextView
            android:id="@+id/label_faucet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Faucet"
            android:textColor="#000000"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/buy"
            app:layout_constraintStart_toStartOf="@id/buy"
            app:layout_constraintEnd_toEndOf="@id/buy" />

        <TextView
            android:id="@+id/label_send"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Send"
            android:textColor="#000000"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/send"
            app:layout_constraintStart_toStartOf="@id/send"
            app:layout_constraintEnd_toEndOf="@id/send" />

        <TextView
            android:id="@+id/label_receive"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Receive"
            android:textColor="#000000"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/receiveicon"
            app:layout_constraintStart_toStartOf="@id/receiveicon"
            app:layout_constraintEnd_toEndOf="@id/receiveicon" />

        <TextView
            android:id="@+id/label_swap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Swap"
            android:textColor="#000000"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/swap"
            app:layout_constraintStart_toStartOf="@id/swap"
            app:layout_constraintEnd_toEndOf="@id/swap" />

        <!-- Spacer between Row 1 and Row 2 -->
        <View
            android:id="@+id/spacer1"
            android:layout_width="0dp"
            android:layout_height="20dp"
            app:layout_constraintTop_toBottomOf="@id/label_faucet"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ==================== ROW 2: Account, Broker, News, Community ==================== -->

        <!-- Row 2 Icons (4 icons in a row) -->
        <ImageView
            android:id="@+id/accounts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:src="@drawable/user_icon"
            app:layout_constraintTop_toBottomOf="@id/spacer1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/broker"
            app:layout_constraintHorizontal_chainStyle="packed" />

        <ImageView
            android:id="@+id/broker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:src="@drawable/line_chart_icon"
            app:layout_constraintTop_toBottomOf="@id/spacer1"
            app:layout_constraintStart_toEndOf="@id/accounts"
            app:layout_constraintEnd_toStartOf="@+id/news" />

        <ImageView
            android:id="@+id/news"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:src="@drawable/baseline_newspaper_black_48"
            app:layout_constraintTop_toBottomOf="@id/spacer1"
            app:layout_constraintStart_toEndOf="@id/broker"
            app:layout_constraintEnd_toStartOf="@+id/community" />

        <!-- Community moved to Row 2 (position 4) -->
        <ImageView
            android:id="@+id/community"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:src="@drawable/dao_team_icon"
            app:layout_constraintTop_toBottomOf="@id/spacer1"
            app:layout_constraintStart_toEndOf="@id/news"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Row 2 Labels -->
        <TextView
            android:id="@+id/label_account"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Account"
            android:textColor="#000000"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/accounts"
            app:layout_constraintStart_toStartOf="@id/accounts"
            app:layout_constraintEnd_toEndOf="@id/accounts" />

        <TextView
            android:id="@+id/label_broker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="BrokerFi "
            android:textColor="#000000"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/broker"
            app:layout_constraintStart_toStartOf="@id/broker"
            app:layout_constraintEnd_toEndOf="@id/broker" />

        <TextView
            android:id="@+id/label_news"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="News"
            android:textColor="#000000"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/news"
            app:layout_constraintStart_toStartOf="@id/news"
            app:layout_constraintEnd_toEndOf="@id/news" />

        <TextView
            android:id="@+id/label_community"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Community"
            android:textColor="#000000"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/community"
            app:layout_constraintStart_toStartOf="@id/community"
            app:layout_constraintEnd_toEndOf="@id/community" />

        <!-- NFT icon hidden (visibility=gone) for compatibility with Java code -->
        <ImageView
            android:id="@+id/nft"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:src="@drawable/codepen_icon"
            app:layout_constraintTop_toBottomOf="@id/label_community"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>