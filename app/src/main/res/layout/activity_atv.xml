<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".xc.AtvActivity">

    <!-- Top Bar -->
    <include
        layout="@layout/topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/buytitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:text="@string/activity_atv_activity"
        android:fontFamily="@font/work_sans_black"
        android:textColor="#000000"
        android:textSize="@dimen/text_size_xlarge"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/action_bar" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/textview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:paddingHorizontal="16dp"
        android:text="@string/activity_atv_current_transactions"
        android:textColor="#000000"
        android:textSize="@dimen/text_size_small"
        app:layout_constraintTop_toBottomOf="@id/buytitle" />

    <!-- Transaction List Container (Black Background) -->
    <FrameLayout
        android:id="@+id/container_transactions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintTop_toBottomOf="@id/textview"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Progress Bar (Centered) -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

        <!-- RecyclerView (Fills container) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/transactions_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp"
            android:clipToPadding="false" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>