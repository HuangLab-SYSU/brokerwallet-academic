<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".xc.AddAccountActivity">

    <!-- Top Bar -->
    <include
        layout="@layout/topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title Section -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        android:text="@string/activity_add_account_import_existing"
        android:fontFamily="@font/work_sans_black"
        android:textSize="@dimen/text_size_xlarge"
        android:textStyle="bold"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/action_bar" />

    <TextView
        android:id="@+id/tv_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:text="@string/activity_add_account_private_key_tip"
        android:textSize="@dimen/text_size_normal"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- Form Section -->
    <TextView
        android:id="@+id/tv_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:paddingHorizontal="16dp"
        android:text="@string/activity_add_account_account_privatekey"
        android:textColor="#000000"
        android:textSize="@dimen/text_size_normal"
        app:layout_constraintTop_toBottomOf="@id/tv_description" />

    <EditText
        android:id="@+id/edt_account"
        android:layout_width="match_parent"
        android:layout_height="@dimen/edittext_height"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:background="@drawable/custom_edittext_border"
        android:textSize="@dimen/text_size_small"
        android:inputType="text"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_label" />

    <TextView
        android:id="@+id/tv_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingHorizontal="16dp"
        android:text="@string/activity_add_account_invalid_private_key"
        android:textColor="@color/red_127"
        android:textSize="@dimen/text_size_small"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/edt_account" />

    <!-- Buttons -->
    <LinearLayout
        android:id="@+id/button_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_error">

        <!-- Cancel Button -->
        <android.widget.Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/activity_add_account_cancel"
            android:textSize="@dimen/text_size_normal"
            android:textAllCaps="false"
            android:background="@drawable/custom_button_bg_white"
            android:padding="4dp"
            android:gravity="center"
            android:clickable="true"
            android:layout_marginEnd="16dp" />

        <!-- Save Button -->
        <android.widget.Button
            android:id="@+id/btn_saveacc"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/activity_add_account_save"
            android:textAllCaps="false"
            android:textSize="@dimen/text_size_normal"
            android:textColor="#ffffff"
            android:background="@drawable/custom_button_background"
            android:padding="4dp"
            android:gravity="center"
            android:clickable="true"
            />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
