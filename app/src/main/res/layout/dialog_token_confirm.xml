<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="328dp"
    android:layout_height="wrap_content"
    android:background="@drawable/token_dialog_bg"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="22dp"
    android:paddingEnd="22dp"
    android:paddingBottom="22dp">

    <TextView
        android:id="@+id/token_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:textColor="#111827"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/token_dialog_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="2dp"
        android:text="@string/token_confirm_subtitle"
        android:textColor="#64748B"
        android:textSize="13sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/token_confirm_details"
        android:textColor="#111827"
        android:textSize="13sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/token_card_surface"
        android:maxHeight="280dp"
        android:padding="0dp">

        <TextView
            android:id="@+id/token_dialog_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="8dp"
            android:padding="16dp"
            android:textColor="#0F172A"
            android:textSize="14sp" />
    </ScrollView>

    <TextView
        android:id="@+id/token_dialog_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:lineSpacingExtra="2dp"
        android:text="@string/token_confirm_warning"
        android:textColor="#92400E"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/token_dialog_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/token_card_surface"
            android:backgroundTint="@null"
            android:text="@string/token_confirm_cancel"
            android:textAllCaps="false"
            android:textColor="#334155"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/token_dialog_confirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/token_btn_primary_selector"
            android:backgroundTint="@null"
            android:text="@string/token_confirm_ok"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
