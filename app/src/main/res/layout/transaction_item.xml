<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/spacing_medium"
    android:paddingVertical="@dimen/spacing_medium">

    <!-- Main Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/transaction_container"
        android:padding="@dimen/spacing_small"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Header Section (Green Background) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#4CAF50"
            android:paddingVertical="@dimen/spacing_small"
            app:layout_constraintTop_toTopOf="@id/container"
            app:layout_constraintStart_toStartOf="@id/container"
            app:layout_constraintEnd_toEndOf="@id/container">

            <!-- Header Labels Row - Fixed Width for Alignment -->
            <TextView
                android:id="@+id/label_type"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:text="@string/transaction_item_type"
                android:textSize="@dimen/text_size_small"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintStart_toStartOf="@id/header_section"
                app:layout_constraintTop_toTopOf="@id/header_section"
                app:layout_constraintEnd_toStartOf="@id/label_amount" />

            <TextView
                android:id="@+id/label_amount"
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="@string/transaction_item_amount"
                android:textSize="@dimen/text_size_small"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintStart_toEndOf="@id/label_type"
                app:layout_constraintTop_toTopOf="@id/header_section"
                app:layout_constraintEnd_toStartOf="@id/label_status" />

            <TextView
                android:id="@+id/label_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/transaction_item_status"
                android:textSize="@dimen/text_size_small"
                android:textColor="#2E7D32"
                android:textStyle="bold"
                android:gravity="center"
                app:layout_constraintStart_toEndOf="@id/label_amount"
                app:layout_constraintTop_toTopOf="@id/header_section"
                app:layout_constraintEnd_toEndOf="@id/header_section" />

            <!-- Header Data Row -->
            <TextView
                android:id="@+id/transaction_type"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_normal"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toStartOf="@id/header_section"
                app:layout_constraintTop_toBottomOf="@id/label_type"
                app:layout_constraintBottom_toBottomOf="@id/header_section"
                app:layout_constraintEnd_toStartOf="@id/transaction_amount" />

            <TextView
                android:id="@+id/transaction_amount"
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_normal"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toEndOf="@id/transaction_type"
                app:layout_constraintTop_toBottomOf="@id/label_amount"
                app:layout_constraintBottom_toBottomOf="@id/header_section"
                app:layout_constraintEnd_toStartOf="@id/transaction_status" />

            <TextView
                android:id="@+id/transaction_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/transaction_item_completed"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_normal"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toEndOf="@id/transaction_amount"
                app:layout_constraintTop_toBottomOf="@id/label_status"
                app:layout_constraintBottom_toBottomOf="@id/header_section"
                app:layout_constraintEnd_toEndOf="@id/header_section" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Details Section (Dark Background) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/details_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A1A"
            android:layout_marginTop="@dimen/spacing_tiny"
            app:layout_constraintTop_toBottomOf="@id/header_section"
            app:layout_constraintStart_toStartOf="@id/container"
            app:layout_constraintEnd_toEndOf="@id/container">

            <!-- FROM Row - Fixed Width Label (80dp) -->
            <TextView
                android:id="@+id/label_from"
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:text="@string/transaction_item_from"
                android:textSize="@dimen/text_size_small"
                android:textColor="#FFFFFF"
                android:paddingVertical="@dimen/spacing_tiny"
                app:layout_constraintStart_toStartOf="@id/details_section"
                app:layout_constraintTop_toTopOf="@id/details_section"
                app:layout_constraintEnd_toStartOf="@id/transaction_from" />

            <TextView
                android:id="@+id/transaction_from"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_small"
                android:paddingVertical="@dimen/spacing_tiny"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toEndOf="@id/label_from"
                app:layout_constraintTop_toTopOf="@id/details_section"
                app:layout_constraintEnd_toEndOf="@id/details_section" />

            <!-- TO Row - Fixed Width Label (80dp) -->
            <TextView
                android:id="@+id/label_to"
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:text="@string/transaction_item_to"
                android:textSize="@dimen/text_size_small"
                android:textColor="#FFFFFF"
                android:paddingVertical="@dimen/spacing_tiny"
                android:background="@drawable/custom_grid_background"
                app:layout_constraintStart_toStartOf="@id/details_section"
                app:layout_constraintTop_toBottomOf="@id/label_from"
                app:layout_constraintEnd_toStartOf="@id/transaction_to" />

            <TextView
                android:id="@+id/transaction_to"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_small"
                android:paddingVertical="@dimen/spacing_tiny"
                android:background="@drawable/custom_grid_background"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toEndOf="@id/label_to"
                app:layout_constraintTop_toBottomOf="@id/transaction_from"
                app:layout_constraintEnd_toEndOf="@id/details_section" />

            <!-- TIME Row - Fixed Width Label (80dp) -->
            <TextView
                android:id="@+id/label_time"
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:text="@string/transaction_item_time"
                android:textSize="@dimen/text_size_small"
                android:textColor="#FFFFFF"
                android:paddingVertical="@dimen/spacing_tiny"
                android:background="@drawable/custom_grid_background"
                app:layout_constraintStart_toStartOf="@id/details_section"
                app:layout_constraintTop_toBottomOf="@id/label_to"
                app:layout_constraintEnd_toStartOf="@id/transaction_time" />

            <TextView
                android:id="@+id/transaction_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_small"
                android:paddingVertical="@dimen/spacing_tiny"
                android:background="@drawable/custom_grid_background"
                app:layout_constraintStart_toEndOf="@id/label_time"
                app:layout_constraintTop_toBottomOf="@id/transaction_to"
                app:layout_constraintEnd_toEndOf="@id/details_section" />

            <!-- FEE Row - Fixed Width Label (80dp) -->
            <TextView
                android:id="@+id/label_fee"
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:text="@string/transaction_item_fee"
                android:textSize="@dimen/text_size_small"
                android:textColor="#FFFFFF"
                android:paddingVertical="@dimen/spacing_tiny"
                android:background="@drawable/custom_grid_background"
                app:layout_constraintStart_toStartOf="@id/details_section"
                app:layout_constraintTop_toBottomOf="@id/label_time"
                app:layout_constraintEnd_toStartOf="@id/transaction_fee" />

            <TextView
                android:id="@+id/transaction_fee"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_small"
                android:paddingVertical="@dimen/spacing_tiny"
                android:background="@drawable/custom_grid_background"
                app:layout_constraintStart_toEndOf="@id/label_fee"
                app:layout_constraintTop_toBottomOf="@id/transaction_time"
                app:layout_constraintEnd_toEndOf="@id/details_section" />

            <!-- ID Row - Fixed Width Label (80dp) -->
            <TextView
                android:id="@+id/label_id"
                android:layout_width="45dp"
                android:layout_height="wrap_content"
                android:text="@string/transaction_item_id"
                android:textSize="@dimen/text_size_small"
                android:textColor="#FFFFFF"
                android:paddingVertical="@dimen/spacing_tiny"
                android:background="@drawable/custom_grid_background"
                app:layout_constraintStart_toStartOf="@id/details_section"
                app:layout_constraintTop_toBottomOf="@id/label_fee"
                app:layout_constraintEnd_toStartOf="@id/transaction_id" />

            <TextView
                android:id="@+id/transaction_id"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/text_size_small"
                android:paddingVertical="@dimen/spacing_tiny"
                android:background="@drawable/custom_grid_background"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintStart_toEndOf="@id/label_id"
                app:layout_constraintTop_toBottomOf="@id/transaction_fee"
                app:layout_constraintEnd_toEndOf="@id/details_section" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>