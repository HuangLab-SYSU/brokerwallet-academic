<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <include layout="@layout/topbar" />

    <include
        android:id="@+id/token_add_help_toolbar_include"
        layout="@layout/include_token_page_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/action_bar" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/token_add_help_toolbar_include"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/token_add_help_intro_label"
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/token_card_surface"
                android:lineSpacingExtra="5dp"
                android:padding="16dp"
                android:text="@string/token_add_help_intro"
                android:textColor="#374151"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/token_add_help_format_label"
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/token_card_surface"
                android:lineSpacingExtra="5dp"
                android:padding="16dp"
                android:text="@string/token_add_help_format"
                android:textColor="#374151"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/token_add_help_standard_label"
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/token_card_surface"
                android:lineSpacingExtra="5dp"
                android:padding="16dp"
                android:text="@string/token_add_help_standard"
                android:textColor="#374151"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/token_add_help_notice_label"
                android:textColor="#64748B"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/token_card_surface"
                android:lineSpacingExtra="5dp"
                android:padding="16dp"
                android:text="@string/token_add_help_notice"
                android:textColor="#374151"
                android:textSize="14sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>
