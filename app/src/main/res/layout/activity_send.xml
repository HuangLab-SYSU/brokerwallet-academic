<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".xc.SendActivity">

    <!-- Top Bar -->
    <include
        layout="@layout/topbar"
        android:id="@+id/action_bar"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Title Section -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:paddingHorizontal="16dp"
        android:text="Send"
        android:fontFamily="@font/work_sans_black"
        android:textSize="@dimen/text_size_xlarge"
        android:textStyle="bold"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/action_bar" />

    <!-- Description Text -->
    <TextView
        android:id="@+id/tv_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        android:text="Transfer your coins securely to another address"
        android:textSize="@dimen/text_size_normal"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <!-- Scrollable Form Area -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_description"
        app:layout_constraintBottom_toTopOf="@id/btn_send">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Send From Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Send from"
                android:textColor="#000000"
                android:textSize="@dimen/text_size_normal" />

            <!-- Send From Input -->
            <EditText
                android:id="@+id/edt_sendfrom"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edittext_height"
                android:layout_marginTop="8dp"
                android:background="@drawable/custom_edittext_border"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textSize="@dimen/text_size_normal" />

            <!-- Send To Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Send to"
                android:textColor="#000000"
                android:textSize="@dimen/text_size_normal" />

            <!-- Send To Input -->
            <EditText
                android:id="@+id/edt_sendto"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edittext_height"
                android:layout_marginTop="8dp"
                android:background="@drawable/custom_edittext_border"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textSize="@dimen/text_size_normal" />

            <!-- Amount Label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Amount"
                android:textColor="#000000"
                android:textSize="@dimen/text_size_normal" />

            <!-- Amount Input -->
            <EditText
                android:id="@+id/edt_amount"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edittext_height"
                android:layout_marginTop="8dp"
                android:background="@drawable/custom_edittext_border"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textSize="@dimen/text_size_normal" />

            <!-- Fee Label -->
            <TextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Fee"
                android:textColor="#000000"
                android:textSize="@dimen/text_size_normal" />

            <!-- Fee Input -->
            <EditText
                android:id="@+id/edt_amount2"
                android:layout_width="match_parent"
                android:layout_height="@dimen/edittext_height"
                android:layout_marginTop="8dp"
                android:background="@drawable/custom_edittext_border"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textSize="@dimen/text_size_normal" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Send Button -->
    <android.widget.Button
        android:id="@+id/btn_send"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height_large"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/custom_button_background"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:text="Send"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/text_size_normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>